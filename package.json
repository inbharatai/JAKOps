{
  "name": "jak-swarm",
  "version": "0.1.0-beta.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:unit": "vitest run",
    "test:e2e": "pnpm --filter @jak-swarm/tests run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "h0:seed": "tsx scripts/seed-h0-demo.ts",
    "h0:check": "tsx scripts/check-h0-demo.ts",
    "h0:setup": "pnpm --filter @jak-swarm/db db:generate && pnpm --filter @jak-swarm/db db:migrate:deploy && pnpm h0:seed",
    "prisma": "node scripts/prisma-guard.js",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:migrate:deploy": "pnpm --filter @jak-swarm/db run db:migrate:deploy",
    "db:migrate:status": "pnpm --filter @jak-swarm/db run db:migrate:status",
    "db:migrate:reset": "pnpm --filter @jak-swarm/db run db:migrate:reset",
    "db:execute": "pnpm --filter @jak-swarm/db run db:execute --",
    "db:seed": "pnpm --filter @jak-swarm/db db:seed",
    "seed:compliance": "pnpm --filter @jak-swarm/db db:seed:compliance",
    "seed:audit-demo": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/seed-audit-demo.ts",
    "db:studio": "pnpm --filter @jak-swarm/db run db:studio",
    "start:dev": "bash scripts/start-dev.sh",
    "check:truth": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/check-docs-truth.ts",
    "audit:tools": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/audit-all-tools.ts",
    "audit:approval-paths": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/audit-approval-paths.ts",
    "bench:search": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/bench-search.ts",
    "bench:vibe-coder": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/bench-vibe-coder.ts",
    "bench:runtime": "pnpm --filter @jak-swarm/tests exec tsx ../scripts/bench-runtime.ts",
    "automation:probe-tokens": "bash scripts/automation/probe-tokens.sh",
    "deploy:railway:docs": "node -e \"console.log('Read docs/railway-deployment.md and configure Railway services from scripts/automation/env-templates/railway-*.env.example')\"",
    "legacy:render:verify-split": "bash scripts/verify-render-split.sh",
    "legacy:render:provision-worker": "bash scripts/automation/provision-render-worker.sh",
    "legacy:render:sync-env": "bash scripts/automation/sync-env-to-render.sh",
    "automation:supabase-redirects": "bash scripts/automation/configure-supabase-redirects.sh",
    "automation:vercel-env": "bash scripts/automation/configure-vercel-env.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "protobufjs": ">=8.4.1",
      "langsmith": "0.7.1",
      "music-metadata": ">=11.12.3",
      "@fastify/static": "9.1.1",
      "@hono/node-server": "1.19.13",
      "axios": "1.16.0",
      "minimatch@3.1.5>brace-expansion": "1.1.13",
      "minimatch@5.1.9>brace-expansion": "2.0.3",
      "minimatch@9.0.9>brace-expansion": "2.0.3",
      "minimatch@10.2.5>brace-expansion": "5.0.6",
      "cheerio>undici": "7.28.0",
      "dompurify": "3.4.0",
      "fast-jwt": "6.2.4",
      "fast-uri": "3.1.2",
      "fastify": ">=5.8.5",
      "hono": "4.12.25",
      "ip-address": "10.1.1",
      "nodemailer": "9.0.1",
      "postcss": "8.5.14",
      "uuid": "11.1.1",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "@whiskeysockets/eslint-config": "https://codeload.github.com/whiskeysockets/eslint-config/tar.gz/299e8389baf62f9aa3034de18ff0d62cc0a5e838",
      "libsignal": "https://codeload.github.com/WhiskeySockets/libsignal-node/tar.gz/1c30d7d7e76a3b0aa120b04dc6a26f5a12dccf67",
      "tmp": ">=0.2.7",
      "tar": ">=7.5.7",
      "@grpc/grpc-js": ">=1.14.4"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-hm7r-c7qw-ghp6",
        "GHSA-mvf2-f6gm-w987",
        "GHSA-rp9m-7r4c-75qg",
        "GHSA-r6q2-hw4h-h46w",
        "GHSA-hmw2-7cc7-3qxx",
        "GHSA-3qcw-2rhx-2726"
      ]
    }
  }
}
