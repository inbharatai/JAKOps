# ─── Required for production builds ──────────────────────────────────────
# Public URL of the deployed JAK API. Without this, a production build
# fails fast with `MISCONFIGURED_API_URL` instead of silently calling
# localhost (the failure mode that shipped to jakswarm.com pre-P0-A).
# Railway API URL pattern:
#   https://<railway-api-domain>
NEXT_PUBLIC_API_URL=https://your-railway-api-domain

# Supabase project URL + anon key. The browser uses these directly for
# auth; they're public-safe (anon key) by Supabase design.
# Use the project origin only (https://<ref>.supabase.co), NOT .../rest/v1.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Local-dev only ──────────────────────────────────────────────────────
# Skip Supabase entirely and use the API's hard-coded dev bypass token.
# Paired with `JAK_DEV_AUTH_BYPASS=1` on the API side. Production builds
# strip NEXT_PUBLIC_* flags they don't see, so this can't accidentally
# ship to prod.
# NEXT_PUBLIC_JAK_DEV_AUTH_BYPASS=1

# ─── Vercel-managed (do NOT set manually) ────────────────────────────────
# VERCEL_OIDC_TOKEN — Vercel CLI writes this to .env.local on first link.
# Do not commit it; the .gitignore already excludes .env.local.
