# Railway worker service env template.
# Copy values into Railway service variables. Do not commit real secrets.

NODE_ENV=production
LOG_LEVEL=info
WORKFLOW_WORKER_INSTANCE_ID=${RAILWAY_SERVICE_NAME}
WORKFLOW_QUEUE_CONCURRENCY=2
WORKFLOW_QUEUE_POLL_INTERVAL_MS=1000
WORKFLOW_QUEUE_LEASE_TTL_MS=60000
WORKER_METRICS_PORT=9464
REQUIRE_REDIS_IN_PROD=true

DATABASE_URL=
DIRECT_URL=
# Railway managed Redis service reference (preferred for this topology).
REDIS_URL=${{Redis.REDIS_URL}}
AUTH_SECRET=
OPENAI_API_KEY=

# Gemini (optional — set LLM_PROVIDER=gemini to activate)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
EVIDENCE_SIGNING_SECRET=
METRICS_TOKEN=

# Optional observability.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
