# Railway API service env template.
# Copy values into Railway service variables. Do not commit real secrets.

NODE_ENV=production
LOG_LEVEL=warn
CORS_ORIGINS=https://jakswarm.com,https://www.jakswarm.com
WORKFLOW_WORKER_MODE=standalone
REQUIRE_REDIS_IN_PROD=true

# Railway injects PORT automatically. API_PORT is optional.
# API_PORT=4000

DATABASE_URL=
DIRECT_URL=
# Railway managed Redis service reference (preferred for this topology).
REDIS_URL=${{Redis.REDIS_URL}}
AUTH_SECRET=
OPENAI_API_KEY=

# Gemini (optional — set LLM_PROVIDER=gemini to activate)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
EVIDENCE_SIGNING_SECRET=
METRICS_TOKEN=

# Optional observability.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
