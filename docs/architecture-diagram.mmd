        T3["🌐 Browser · 🔍 Research"]
        T4["📊 Spreadsheet · 🧠 Knowledge"]
        T5["MCP: Slack · GitHub · Notion"]
    end

    subgraph SHIELD_OUT["🛡️ JAK Shield — Tool Gate"]
        RISK["Risk Classifier\n6-tier lattice"]
        PERM["Permission Layer\ntenant allowlists"]
        AUDIT["Audit Logger\nHMAC-SHA256 signed"]
    end

    subgraph STATE["💾 Durable State"]
        PG[("PostgreSQL\nLangGraph Checkpoints\nAudit Logs · Traces")]
        RD[("Redis\nJob Queue · Cron\nVoice Sessions")]
    end

    subgraph MCP["🔌 21 MCP Connectors"]
        direction LR
        M1["Slack · GitHub · Google Drive"]
        M2["Notion · Stripe · HubSpot"]
        M3["Salesforce · Airtable · +13"]
