        VER["✅ Verifier\nchecks output vs goal"]
        GRD["🛡️ Guardrail\npolicy enforcement"]
        APR["⚠️ Approval Gate\nhuman-in-the-loop"]
    end

    subgraph WORKERS["⚡ Worker Layer — 32 Specialist Agents"]
        direction LR
        EXEC["💼 Executive\nCEO · CTO · CFO · CMO"]
        OPS["🏢 Operations\nContent · SEO · Legal · Analytics"]
        CORE["⚙️ Core\nEmail · Calendar · CRM · Browser"]
        VIBE["⚡ Vibe Coding\nArchitect · Generator · Debugger"]
    end

    subgraph PROVIDERS["🧠 LLM Provider Layer"]
        direction LR
        OAI["OpenAI\nGPT-5.5 · GPT-5.4"]
        GEM["Gemini\n2.5 Pro · Flash · Flash-Lite"]
    end

    subgraph TOOLS["🔧 122 Classified Tools"]
        direction LR
        T1["📧 Email · 📅 Calendar"]
