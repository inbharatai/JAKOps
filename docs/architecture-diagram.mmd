    A --> INJ
    B --> INJ
    INJ --> CMD
    CYB --> CMD
    CMD --> PLN --> GRD
    GRD -->|"✅ Pass"| RTR
    GRD -->|"🚫 Block"| CMD
    RTR --> WORKERS
    WORKERS --> PROVIDERS
    PROVIDERS --> WORKERS
    WORKERS --> TOOLS
    TOOLS --> RISK
    RISK -->|"READ_ONLY"| AUDIT
    RISK -->|"DESTRUCTIVE"| APR
    APR -->|"👍 Approved"| AUDIT
    APR -->|"👎 Rejected"| CMD
    AUDIT --> VER
    VER -->|"✅ Pass"| OUTPUT["📊 Compiled Result"]
    VER -->|"❌ Fail"| PLN

    WORKERS <--> PG
    WORKERS <--> RD
    TOOLS <--> MCP

